@prefix shexmap:     <https://shexmap.example.org/ontology#> .
@prefix shexrmap:    <https://shexmap.example.org/resource/map/> .
@prefix shexrschema: <https://shexmap.example.org/resource/schema/> .
@prefix shexruser:   <https://shexmap.example.org/resource/user/> .
@prefix dct:         <http://purl.org/dc/terms/> .
@prefix dcat:        <http://www.w3.org/ns/dcat#> .
@prefix schema:      <https://schema.org/> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .

# ─── Individual ShExMaps ──────────────────────────────────────────────────────

shexrmap:bpfhir a shexmap:ShExMap ;
    dct:title "Blood Pressure FHIR ShEx" ;
    dct:description "ShEx schema for a FHIR RDF blood pressure observation, annotated with ShExMap variables for bidirectional mapping." ;
    shexmap:fileName "bpfhir.shex" ;
    shexmap:fileFormat "shexc" ;
    dct:source <https://shexmap.example.org/api/v1/files/bpfhir.shex> ;
    shexmap:hasSchema shexrschema:bpfhir ;
    dcat:keyword "fhir" ;
    dcat:keyword "blood-pressure" ;
    dcat:keyword "clinical" ;
    schema:version "1.0.0" ;
    dct:creator shexruser:seed-author ;
    dct:created "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    dct:modified "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    shexmap:stars 0 .

shexrmap:bpdam a shexmap:ShExMap ;
    dct:title "Blood Pressure DAM ShEx" ;
    dct:description "ShEx schema for a Data Access Model (DAM) blood pressure representation, annotated with ShExMap variables for bidirectional mapping." ;
    shexmap:fileName "bpdam.shex" ;
    shexmap:fileFormat "shexc" ;
    dct:source <https://shexmap.example.org/api/v1/files/bpdam.shex> ;
    shexmap:hasSchema shexrschema:bpdam ;
    dcat:keyword "dam" ;
    dcat:keyword "blood-pressure" ;
    dcat:keyword "clinical" ;
    schema:version "1.0.0" ;
    dct:creator shexruser:seed-author ;
    dct:created "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    dct:modified "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    shexmap:stars 0 .
