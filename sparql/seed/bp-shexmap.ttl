@prefix shexmap:     <https://shexmap.example.org/ontology#> .
@prefix shexrmap:    <https://shexmap.example.org/resource/map/> .
@prefix shexrschema: <https://shexmap.example.org/resource/schema/> .
@prefix shexruser:   <https://shexmap.example.org/resource/user/> .
@prefix shexrfile:   <https://shexmap.example.org/resource/file/> .
@prefix dct:         <http://purl.org/dc/terms/> .
@prefix dcat:        <http://www.w3.org/ns/dcat#> .
@prefix schema:      <https://schema.org/> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .

# ─── ShEx file resources ──────────────────────────────────────────────────────

shexrfile:bpfhir a shexmap:ShExFile ;
    dct:title "Blood Pressure FHIR ShEx" ;
    shexmap:fileName "bpfhir.shex" ;
    shexmap:fileFormat "shexc" ;
    dct:source <https://shexmap.example.org/api/v1/files/bpfhir.shex> .

shexrfile:bpdam a shexmap:ShExFile ;
    dct:title "Blood Pressure DAM ShEx" ;
    shexmap:fileName "bpdam.shex" ;
    shexmap:fileFormat "shexc" ;
    dct:source <https://shexmap.example.org/api/v1/files/bpdam.shex> .

# ─── ShExMap: Blood Pressure FHIR ↔ DAM ──────────────────────────────────────

shexrmap:bp-fhir-dam a shexmap:ShExMap ;
    dct:identifier "bp-fhir-dam" ;
    dct:title "Blood Pressure: FHIR RDF to DAM" ;
    dct:description "Bidirectional ShExMap between a FHIR RDF blood pressure observation and a Data Access Model (DAM) representation. Maps patient name, systolic/diastolic values and units via shared bp: mapping variables." ;
    shexmap:hasSourceFile shexrfile:bpfhir ;
    shexmap:hasTargetFile shexrfile:bpdam ;
    shexmap:sourceSchema shexrschema:bpfhir ;
    shexmap:targetSchema shexrschema:bpdam ;
    dcat:keyword "fhir" ;
    dcat:keyword "dam" ;
    dcat:keyword "blood-pressure" ;
    dcat:keyword "clinical" ;
    schema:version "1.0.0" ;
    dct:creator shexruser:seed-author ;
    dct:created "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    dct:modified "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    shexmap:stars 0 .
