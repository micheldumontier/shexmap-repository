@prefix shexmap:     <https://shexmap.example.org/ontology#> .
@prefix shexrmap:    <https://shexmap.example.org/resource/map/> .
@prefix shexrschema: <https://shexmap.example.org/resource/schema/> .
@prefix shexruser:   <https://shexmap.example.org/resource/user/> .
@prefix dct:         <http://purl.org/dc/terms/> .
@prefix dcat:        <http://www.w3.org/ns/dcat#> .
@prefix schema:      <https://schema.org/> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:        <http://www.w3.org/ns/prov#> .

# ─── Sample user ──────────────────────────────────────────────────────────────

shexruser:seed-author a schema:Person ;
    schema:identifier "seed-author" ;
    schema:name "Seed Author" ;
    schema:email "seed@example.org" .

# ─── Sample ShExMap 1: FHIR Patient → Schema.org Person ──────────────────────

shexrmap:00000000-0000-0000-0000-000000000001 a shexmap:ShExMap ;
    dct:identifier "00000000-0000-0000-0000-000000000001" ;
    dct:title "FHIR Patient to Schema.org Person" ;
    dct:description "Maps an HL7 FHIR R4 Patient resource to a Schema.org Person entity." ;
    shexmap:mappingContent "# ShExMap: FHIR Patient to Schema.org Person" ;
    shexmap:sourceSchema shexrschema:fhir-r4 ;
    shexmap:targetSchema shexrschema:schema-org ;
    dcat:keyword "fhir" ;
    dcat:keyword "schema.org" ;
    dcat:keyword "patient" ;
    schema:version "1.0.0" ;
    dct:license <https://spdx.org/licenses/Apache-2.0.html> ;
    dct:creator shexruser:seed-author ;
    dct:created "2024-01-15T10:00:00Z"^^xsd:dateTime ;
    dct:modified "2024-01-15T10:00:00Z"^^xsd:dateTime ;
    shexmap:stars 12 .

# ─── Sample ShExMap 2: Wikidata Human → Schema.org Person ────────────────────

shexrmap:00000000-0000-0000-0000-000000000002 a shexmap:ShExMap ;
    dct:identifier "00000000-0000-0000-0000-000000000002" ;
    dct:title "Wikidata Human to Schema.org Person" ;
    dct:description "Maps a Wikidata human entity (Q5) to a Schema.org Person." ;
    shexmap:mappingContent "# ShExMap: Wikidata Human to Schema.org Person" ;
    shexmap:sourceSchema shexrschema:wikidata ;
    shexmap:targetSchema shexrschema:schema-org ;
    dcat:keyword "wikidata" ;
    dcat:keyword "schema.org" ;
    dcat:keyword "human" ;
    schema:version "1.1.0" ;
    dct:creator shexruser:seed-author ;
    dct:created "2024-02-20T14:30:00Z"^^xsd:dateTime ;
    dct:modified "2024-03-01T09:15:00Z"^^xsd:dateTime ;
    shexmap:stars 7 .
