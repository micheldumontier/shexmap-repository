@prefix shexmap:     <https://shexmap.example.org/ontology#> .
@prefix shexrmap:    <https://shexmap.example.org/resource/map/> .
@prefix shexrpair:   <https://shexmap.example.org/resource/pairing/> .
@prefix shexruser:   <https://shexmap.example.org/resource/user/> .
@prefix dct:         <http://purl.org/dc/terms/> .
@prefix dcat:        <http://www.w3.org/ns/dcat#> .
@prefix schema:      <https://schema.org/> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .

# ─── ShExMap Pairing: Blood Pressure FHIR ↔ DAM ──────────────────────────────

shexrpair:bp-fhir-dam a shexmap:ShExMapPairing ;
    dct:identifier "bp-fhir-dam" ;
    dct:title "Blood Pressure: FHIR RDF ↔ DAM" ;
    dct:description "Bidirectional ShExMap pairing between a FHIR RDF blood pressure observation and a Data Access Model (DAM) representation. Maps patient name, systolic/diastolic values and units via shared bp: mapping variables." ;
    shexmap:sourceMap shexrmap:bpfhir ;
    shexmap:targetMap shexrmap:bpdam ;
    dcat:keyword "fhir" ;
    dcat:keyword "dam" ;
    dcat:keyword "blood-pressure" ;
    dcat:keyword "clinical" ;
    schema:version "1.0.0" ;
    dct:creator shexruser:seed-author ;
    dct:created "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    dct:modified "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    shexmap:stars 0 .
