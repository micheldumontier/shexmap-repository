<https://w3id.org/shexmap/resource/version/0bcb827f-ef20-4aab-800e-b9c9870a9193-v1> <https://w3id.org/shexmap/ontology#versionContent> "PREFIX  : <http://dam.example/med#>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\nPREFIX bp: <http://shex.io/extensions/Map/#BPDAM->\r\nPREFIX Map: <http://shex.io/extensions/Map/#>\r\n\r\nstart = @<BPunitsDAM>\r\n\r\n<BPunitsDAM> {\r\n  :name . %Map:{ regex(/(?<bp:family>[a-zA-Z]+), (?<bp:given>[a-zA-Z]+)/) %};\r\n  :systolic {\r\n    :value xsd:float %Map:{ bp:sysVal %};\r\n    :units xsd:string %Map:{ bp:sysUnits %}\r\n  };\r\n  :diastolic {\r\n    :value xsd:float %Map:{ bp:diaVal %};\r\n    :units xsd:string %Map:{ bp:diaUnits %}\r\n  };\r\n  :someConstProp xsd:string? %Map:{ <http://abc.example/someConstant> %}\r\n}\r\n" .
<https://w3id.org/shexmap/resource/map/2f4ce490-e627-4b09-bbda-97186994f4e1> <https://w3id.org/shexmap/ontology#sampleTurtleData> "PREFIX  : <http://w3id.org/sulo/ext/>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\nPREFIX bp: <http://shex.io/extensions/Map/#BPDAM->\r\nPREFIX Map: <http://shex.io/extensions/Map/#>\r\nPREFIX sulo: <https://w3id.org/sulo/>\r\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\n\r\n<tag:b1> \r\n sulo:hasFeature [ \r\n    a :GivenName; \r\n    sulo:hasValue \"Alice\"\r\n ], [\r\n   a :FamilyName;\r\n     sulo:hasValue \"Walker\"\r\n], [\r\n   a :SystolicBloodPressure;\r\n   sulo:hasValue \"110\"^^xsd:float;\r\n   sulo:hasPart [ a sulo:Unit; rdfs:label \"mmHg\"^^xsd:string]\r\n], [\r\n   a :DiastolicBloodPressure;\r\n   sulo:hasValue \"70\"^^xsd:float;\r\n   sulo:hasPart [ a sulo:Unit; rdfs:label \"mmHg\"^^xsd:string]\r\n] .\r\n" .
<https://w3id.org/shexmap/resource/version/2f4ce490-e627-4b09-bbda-97186994f4e1-v2> <https://w3id.org/shexmap/ontology#versionContent> "PREFIX  : <http://w3id.org/sulo/ext/>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\nPREFIX bp: <http://shex.io/extensions/Map/#BPDAM->\r\nPREFIX Map: <http://shex.io/extensions/Map/#>\r\nPREFIX sulo: <https://w3id.org/sulo/>\r\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\n\r\nstart = @<SULO_Patient>\r\n\r\n<SULO_Patient> {\r\n  a [:Patient]?;\r\n  sulo:hasFeature @<SULO_GivenName>*;\r\n  sulo:hasFeature @<SULO_FamilyName>* ;\r\n  sulo:hasFeature @<SULO_SystolicBP>* ;\r\n  sulo:hasFeature @<SULO_DiastolicBP>* \r\n}\r\n<SULO_GivenName> {\r\n  a [:GivenName]?;\r\n  sulo:hasValue xsd:string %Map:{ bp:given %}\r\n}\r\n<SULO_FamilyName> {\r\n  a [:FamilyName]?;\r\n  sulo:hasValue xsd:string %Map:{ bp:family %}\r\n}\r\n<SULO_SystolicBP> {\r\n  a [:SystolicBloodPressure]?;\r\n  sulo:hasValue xsd:float %Map:{ bp:sysVal %};\r\n  sulo:hasPart @<SULO_SBUnit>\r\n}\r\n<SULO_SBUnit> {\r\n  a [sulo:Unit]?;\r\n  rdfs:label xsd:string %Map:{ bp:sysUnits %}\r\n}\r\n<SULO_DiastolicBP> {\r\n  a [:DiastolicBloodPressure]?;\r\n  sulo:hasValue xsd:float %Map:{ bp:diaVal %};\r\n  sulo:hasPart @<SULO_DBUnit>\r\n}\r\n<SULO_DBUnit> {\r\n  a [sulo:Unit]?;\r\n  rdfs:label xsd:string %Map:{ bp:diaUnits %}\r\n}\r\n\r\n\r\n" .
<https://w3id.org/shexmap/resource/version/2f4ce490-e627-4b09-bbda-97186994f4e1-v1> <https://w3id.org/shexmap/ontology#versionContent> "PREFIX  : <http://w3id.org/sulo/ext/>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\nPREFIX bp: <http://shex.io/extensions/Map/#BPDAM->\r\nPREFIX Map: <http://shex.io/extensions/Map/#>\r\nPREFIX sulo: <https://w3id.org/sulo/>\r\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\n\r\nstart = @<SULO_Patient>\r\n\r\n<SULO_Patient> {\r\n  sulo:hasFeature @<SULO_GivenName>*;\r\n  sulo:hasFeature @<SULO_FamilyName>* ;\r\n  sulo:hasFeature @<SULO_SystolicBP>* ;\r\n  sulo:hasFeature @<SULO_DiastolicBP>* \r\n}\r\n<SULO_GivenName> {\r\n  a :GivenName;\r\n  sulo:hasValue xsd:string %Map:{ bp:given %}\r\n}\r\n<SULO_FamilyName> {\r\n  a :FamilyName;\r\n  sulo:hasValue xsd:string %Map:{ bp:family %}\r\n}\r\n<SULO_SystolicBP> {\r\n  a :SystolicBloodPressure;\r\n  sulo:hasValue xsd:float %Map:{ bp:sysVal %};\r\n  sulo:hasPart @<SULO_SBUnit>\r\n}\r\n<SULO_SBUnit> {\r\n  a sulo:Unit;\r\n  rdfs:label xsd:string %Map:{ bp:sysUnits %}\r\n}\r\n<SULO_DiastolicBP> {\r\n  a :DiastolicBloodPressure;\r\n  sulo:hasValue xsd:float %Map:{ bp:diaVal %};\r\n  sulo:hasPart @<SULO_DBUnit>\r\n}\r\n<SULO_DBUnit> {\r\n  a sulo:Unit;\r\n  rdfs:label xsd:string %Map:{ bp:diaUnits %}\r\n}\r\n\r\n\r\n" .
<https://w3id.org/shexmap/resource/map/0bcb827f-ef20-4aab-800e-b9c9870a9193> <https://w3id.org/shexmap/ontology#sampleTurtleData> "PREFIX : <http://dam.example/med#>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\nPREFIX bp: <http://shex.io/extensions/Map/#BPDAM->\r\nPREFIX Map: <http://shex.io/extensions/Map/#>\r\n\r\n<tag:b0> :name \"Walker, Alice\";\r\n  :systolic [\r\n    :value \"110\"^^xsd:float;\r\n    :units \"mmHg\"\r\n  ];\r\n  :diastolic [\r\n    :value \"70\"^^xsd:float;\r\n    :units \"mmHg\"\r\n  ]." .
<https://w3id.org/shexmap/resource/map/e0bf88ce-9ac4-4222-b8fc-0863d2cbe076> <https://w3id.org/shexmap/ontology#sampleTurtleData> "PREFIX fhir: <http://hl7.org/fhir-rdf/>\r\nPREFIX sct: <http://snomed.info/sct/>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\n\r\n<tag:BPfhir123> a fhir:Observation;\r\n  fhir:subject [\r\n    fhir:givenName \"Alice\";\r\n    fhir:familyName \"Walker\"\r\n  ];\r\n  fhir:coding [\r\n    fhir:code sct:Blood_Pressure\r\n  ];\r\n  fhir:component [\r\n    a fhir:Observation;\r\n    fhir:coding [\r\n      fhir:code sct:Systolic_Blood_Pressure\r\n    ];\r\n    fhir:valueQuantity [\r\n      a fhir:Quantity;\r\n      fhir:value \"110\"^^xsd:float;\r\n      fhir:units \"mmHg\"\r\n    ]\r\n  ], [\r\n    a fhir:Observation;\r\n    fhir:coding [\r\n      fhir:code sct:Diastolic_Blood_Pressure\r\n    ];\r\n    fhir:valueQuantity [\r\n      a fhir:Quantity;\r\n      fhir:value \"70\"^^xsd:float;\r\n      fhir:units \"mmHg\"\r\n    ]\r\n  ]." .
<https://w3id.org/shexmap/resource/version/e0bf88ce-9ac4-4222-b8fc-0863d2cbe076-v1> <https://w3id.org/shexmap/ontology#versionContent> "PREFIX fhir: <http://hl7.org/fhir-rdf/>\r\nPREFIX sct: <http://snomed.info/sct/>\r\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\r\nPREFIX bp: <http://shex.io/extensions/Map/#BPDAM->\r\nPREFIX Map: <http://shex.io/extensions/Map/#>\r\n\r\nstart = @<BPfhir>\r\n\r\n<collector> {\r\n  fhir:item @<BPfhir>*\r\n}\r\n\r\n<Patient> {\r\n  fhir:givenName xsd:string %Map:{ bp:given %};\r\n  fhir:familyName xsd:string %Map:{ bp:family %}\r\n}\r\n\r\n<BPfhir> {\r\n  a [fhir:Observation]?;\r\n  fhir:subject @<Patient>;\r\n  fhir:coding { fhir:code [sct:Blood_Pressure] };\r\n  fhir:component @<sysBP>;\r\n  fhir:component @<diaBP>\r\n}\r\n<sysBP> {\r\n  a [fhir:Observation]?;\r\n  fhir:coding { fhir:code [sct:Systolic_Blood_Pressure] };\r\n  fhir:valueQuantity {\r\n    a [fhir:Quantity]?;\r\n    fhir:value xsd:float %Map:{ bp:sysVal %};\r\n    fhir:units xsd:string %Map:{ bp:sysUnits %}\r\n  }\r\n}\r\n<diaBP> {\r\n  a [fhir:Observation]?;\r\n  fhir:coding { fhir:code [sct:Diastolic_Blood_Pressure] };\r\n  fhir:valueQuantity {\r\n    a [fhir:Quantity]?;\r\n    fhir:value xsd:float %Map:{ bp:diaVal %};\r\n    fhir:units xsd:string %Map:{ bp:diaUnits %}\r\n  }\r\n}\r\n" .
