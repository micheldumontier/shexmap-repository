# Shapes with zero ShExMap coverage (gap analysis)
# Optionally filter by ?schemaUrl
PREFIX shexmap: <https://w3id.org/shexmap/ontology#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?schema ?shape ?shapeLabel (COUNT(DISTINCT ?map) AS ?mappingCount)
WHERE {
  ?shape shexmap:belongsToSchema ?schema .
  OPTIONAL { ?shape rdfs:label ?shapeLabel }
  OPTIONAL {
    ?map a shexmap:ShExMap ;
         shexmap:sourceSchema ?schema .
  }
  # Uncomment and bind to filter by a specific schema:
  # FILTER(?schema = <SCHEMA_URL>)
}
GROUP BY ?schema ?shape ?shapeLabel
HAVING (COUNT(DISTINCT ?map) = 0)
ORDER BY ?schema ?shape
